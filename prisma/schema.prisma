generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Freeboard {
  id          String @id @default(uuid())
  title       String
  content     String
  user_name   String
  heart_count Int

  isDeleted Boolean
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Comment   Comment[]
}

model Comment {
  id        String @id @default(uuid())
  content   String
  user_name String

  isDeleted Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  freeboard   Freeboard? @relation(fields: [freeboardId], references: [id], onDelete: Cascade)
  freeboardId String?
}
