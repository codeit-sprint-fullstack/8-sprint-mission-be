# ==============================
# 상품 목록 조회 (기본)
GET http://localhost:8080/products
Accept: application/json

###

# 상품 목록 조회 (페이지네이션: offset=10, limit=5)
GET http://localhost:8080/products?offset=10&limit=5
Accept: application/json

###

# 상품 목록 조회 (검색: name/description 포함 '노트북')
GET http://localhost:8080/products?q=노트북
Accept: application/json

###

# 상품 목록 조회 (최신순 정렬)
GET http://localhost:8080/products?sort=recent
Accept: application/json

###

# 상품 목록 조회 (검색 + 페이지네이션 + 최신순)
GET http://localhost:8080/products?q=노트북&offset=0&limit=5&sort=recent
Accept: application/json

###

# 상품 등록
POST http://localhost:8080/products
Content-Type: application/json

{
  "name": "노트북",
  "description": "LG Gram 14",
  "price": 1200000,
  "tags": ["전자제품", "중고"]
}

###

# 상품 상세 조회 (등록 후 _id 사용)
GET http://localhost:8080/products/<상품ID>
Accept: application/json

###

# 상품 수정
PATCH http://localhost:8080/products/<상품ID>
Content-Type: application/json

{
  "price": 1000000
}

###

# 상품 삭제
DELETE http://localhost:8080/products/<상품ID>
